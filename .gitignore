# ======================================================
# WildSight .gitignore
# FastAPI + React + Docker + PostgreSQL
# ======================================================

# ======================================================
# Python
# ======================================================

__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Environment variables
.env
.env.*
!.env.example

# Python tooling
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
pip-log.txt
pip-delete-this-directory.txt

# ======================================================
# Django / Flask
# ======================================================

db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache

# ======================================================
# Node / React
# ======================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# React builds
frontend/build/
frontend/dist/
build/
dist/

# ======================================================
# Docker
# ======================================================

docker-compose.override.yml

# Docker volumes (if stored locally)
postgres_data/
pgdata/

# ======================================================
# IDEs
# ======================================================

.vscode/
.idea/

# ======================================================
# Operating System
# ======================================================

.DS_Store
Thumbs.db
Desktop.ini

# ======================================================
# Temporary files
# ======================================================

tmp/
temp/
*.tmp
*.swp
*.swo
*~

# ======================================================
# Documentation builds
# ======================================================

docs/_build/
site/

# ======================================================
# Data files
# ======================================================

uploads/
logs/
cache/

# Large generated datasets
data/raw/
data/processed/

# Machine learning outputs
/models/
checkpoints/

# ======================================================
